{
    "Prompting": {
        "CodebaseDescription": "",
        "CodeCommandStrategy": "update_file",
        "Provider": "OpenAI",
        "ProviderConfig": {
            "ApiKey": "",
            "Model": "gpt-4.1",
            "Temperature": 0.4,
            "MaxTokens": 3000,
            "TopP": 1.0,
            "Timeout": 60
        }
    },
    "CodeOverseer": {
        "CodeDirectory": "./codebase",
        "IgnorePatterns": [
            "**/node_modules/",
            "**/dist/",
            ".vscode/",
            ".git/"
        ],
        "IncludeOnlyPatterns": [
            "*.ts"
        ],
        "RepromptOnChange": true
    },
    "FastApi": {
        "Host": "0.0.0.0",
        "Port": 3000
    },
    "KeypointNotification": {
        "Enabled": true,
        "Endpoint": "http://game-web-wrapper:8001/notify-of-event"
    }
}