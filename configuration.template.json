{
    "Prompting": {
        "CodebaseDescription": "${CODEBASE_DESCRIPTION}",
        "CodeCommandStrategy": "${CODE_COMMAND_STRATEGY}",
        "Provider": "${PROMPTING_PROVIDER}",
        "ProviderConfig": {
            "ApiKey": "${PROMPTING_API_KEY}",
            "Model": "${PROMPTING_MODEL}",
            "Temperature": ${PROMPTING_TEMPERATURE},
            "MaxTokens": ${PROMPTING_MAX_TOKENS},
            "TopP": ${PROMPTING_TOP_P},
            "Timeout": ${PROMPTING_TIMEOUT}
        }
    },
    "CodeOverseer": {
        "CodeDirectory": "${CODE_DIRECTORY}",
        "CodeStagingDirectory": "${CODE_STAGING_DIRECTORY}",
        "IgnorePatterns": [
            "**/node_modules/",
            "**/dist/",
            ".vscode/",
            ".git/"
        ],
        "IncludeOnlyPatterns": [
            "*.ts"
        ],
        "RepromptOnChange": ${REPROMPT_ON_CHANGE}
    },
    "FastApi": {
        "Host": "0.0.0.0",
        "Port": ${FASTAPI_PORT}
    },
    "KeypointNotification": {
        "Enabled": ${KEYPOINT_NOTIFICATION_ENABLED},
        "Endpoint": "${KEYPOINT_NOTIFICATION_ENDPOINT}"
    }
}